# Dragon backend container mode:
# watch | polling | idle | github-watch | github-polling | github-idle
DRAGON_RUN_MODE=watch
DRAGON_POLL_SECONDS=30
DRAGON_MAX_PASSES=10
DRAGON_IDLE_PASSES=2
DRAGON_MAX_CYCLES=100

# Enable these when you want the container to work against live GitHub issues.
DRAGON_GITHUB_OWNER=
DRAGON_GITHUB_REPO=
DRAGON_SYNC_GITHUB=false

# Provider and GitHub credentials.
OPENAI_API_KEY=
GITHUB_TOKEN=
GH_TOKEN=
